@startuml
skinparam defaultFontSize 10
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderThickness 1.5
skinparam sequenceGroupBorderThickness 1.5

actor "Skladník" as Uzivatel
participant ":SkladovyPohyb" as Pohyb
note over Pohyb : instance: PrijemPohyb | VydejPohyb | PresunutiPohyb
participant ":Soucastka" as Soucastka
participant ":Lokace" as Lokace

Uzivatel -> Pohyb : vytvoritPohyb(soucastka, mnozstvi)
activate Pohyb

Pohyb -> Pohyb : overitData()

alt [data nejsou platná]
    Pohyb --> Uzivatel : pohyb zamítnut

else [data jsou platná]
    Pohyb -> Pohyb : provestPohyb()

    alt [PrijemPohyb]
        Pohyb -> Soucastka : zvysMnozstvi(pocet)
        activate Soucastka
        Soucastka --> Pohyb : ok
        deactivate Soucastka
        Pohyb --> Uzivatel : pohyb potvrzen

    else [VydejPohyb]
        Pohyb -> Soucastka : snizMnozstvi(pocet)
        activate Soucastka
        Soucastka --> Pohyb : ok
        deactivate Soucastka
        Pohyb --> Uzivatel : pohyb potvrzen

    else [PresunutiPohyb]
        Pohyb -> Soucastka : overDostupnost()
        activate Soucastka
        alt [součástka nedostupná]
            Soucastka --> Pohyb : chyba
            deactivate Soucastka
            Pohyb --> Uzivatel : pohyb zamítnut
        else [ok]
            Soucastka --> Pohyb : ok
            deactivate Soucastka
            Pohyb -> Lokace : zmenLokaci()
            activate Lokace
            Lokace --> Pohyb : ok
            deactivate Lokace
            Pohyb --> Uzivatel : pohyb potvrzen
        end
    end
end

deactivate Pohyb

@enduml
