@startuml
skinparam defaultFontSize 13
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderThickness 1.5
skinparam sequenceGroupBorderThickness 1.5

' Bod 5: instance konkrétní podtřídy místo abstraktní :SkladovyPohyb
' Bod 5: polymorfismus – provestPohyb() se chová dle podtřídy

actor ":Uživatel" as Uzivatel
participant ":PrijemPohyb" as Pohyb
participant ":Soucastka" as Soucastka
participant ":Lokace" as Lokace

note over Pohyb
  Konkrétní instance může být
  :PrijemPohyb, :VydejPohyb
  nebo :PresunutiPohyb
end note

Uzivatel -> Pohyb : vytvoritPohyb(soucastka, mnozstvi)
activate Pohyb

Pohyb -> Pohyb : overitData()

alt [data nejsou platná]
    Pohyb --> Uzivatel : pohyb zamítnut

else [data jsou platná]
    ' polymorfismus – provestPohyb() se chová dle konkrétní podtřídy
    Pohyb -> Pohyb : provestPohyb()
    activate Pohyb

    Pohyb -> Soucastka : zvysMnozstvi(pocet)
    activate Soucastka
    Soucastka --> Pohyb : ok
    deactivate Soucastka

    deactivate Pohyb
    Pohyb --> Uzivatel : pohyb potvrzen
end

deactivate Pohyb

@enduml
