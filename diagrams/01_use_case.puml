@startuml 01_use_case
top to bottom direction
skinparam actorStyle awesome
skinparam nodesep 50
skinparam ranksep 50
skinparam packagePadding 10

actor "Vedoucí skladu" as Vedouci
actor "Skladník" as Skladnik

rectangle "WMS – Elektronické součástky" {

  package "Skladové pohyby" {
    usecase "Příjem na sklad" as UC_PRIJEM
    usecase "Výdej ze skladu" as UC_VYDEJ
    usecase "Přesun součástky" as UC_PRESUN
    usecase "Vytvořit pohyb" as UC_POHYB
    usecase "Ověřit data pohybu" as UC_OVERIT
  }

  package "Součástky" {
    usecase "Přidat součástku" as UC_ADD
    usecase "Editovat součástku" as UC_EDIT
    usecase "Zobrazit zásoby" as UC_ZASOBY
    usecase "Ověřit dostupnost" as UC_DOSTUPNOST
  }

  package "Projekty" {
    usecase "Spravovat projekt" as UC_PROJEKT
    usecase "Přiřadit součástku\nk projektu" as UC_PRIRADIT
    usecase "Odebrat součástku\nz projektu" as UC_ODEBRAT
  }

}

' Vedoucí skladu vlevo nahoře
Vedouci -- UC_ADD
Vedouci -- UC_EDIT
Vedouci -- UC_ZASOBY
Vedouci -- UC_PROJEKT
Vedouci -- UC_PRIRADIT
Vedouci -- UC_ODEBRAT
Vedouci -- UC_POHYB

' Skladník vlevo dole
Skladnik -- UC_PRIJEM
Skladnik -- UC_VYDEJ
Skladnik -- UC_PRESUN
Skladnik -- UC_ZASOBY

' include
UC_POHYB    ..> UC_OVERIT     : <<include>>
UC_PRIRADIT ..> UC_DOSTUPNOST : <<include>>

' extend
UC_PRIJEM ..> UC_POHYB : <<extend>>
UC_VYDEJ  ..> UC_POHYB : <<extend>>
UC_PRESUN ..> UC_POHYB : <<extend>>

@enduml
