@startuml
scale 1.5
skinparam defaultFontSize 13
skinparam ArrowThickness 1.5
skinparam ActivityBorderThickness 1.5
skinparam ActivityDiamondBorderThickness 1.5
skinparam ActivityBorderColor #444444
skinparam ActivityDiamondBorderColor #444444
skinparam ArrowColor #444444

' Bod 5: polymorfismus – odstraněno větvení dle typu
' provestPohyb() se chová dle konkrétní podtřídy automaticky

start

:Zadat součástku a množství;
:Inicializovat pohyb\n(vytvoritPohyb());
:Ověřit data pohybu\n(overitData());

if (Data platná?) then ([ano])
  :Provést pohyb\n(provestPohyb());
  note right
    Polymorfně – dle podtřídy:
    PrijemPohyb, VydejPohyb
    nebo PresunutiPohyb
  end note
  :Potvrdit pohyb uživateli;

else ([ne])
  :Zamítnout pohyb;
endif

stop
@enduml
