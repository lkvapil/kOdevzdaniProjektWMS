@startuml
top to bottom direction
skinparam CircledCharacterRadius 0
skinparam CircledCharacterFontSize 0
skinparam defaultFontSize 13
skinparam classFontSize 14
skinparam classFontStyle bold
skinparam ArrowFontSize 12
skinparam nodesep 50
skinparam ranksep 60

abstract class Uzivatel {
  id: int
  jmeno: String
  email: String
}

class Skladnik {
}

class VedouciSkladu {
}

class PrijemPohyb {
  dodavatel: String
  vytvoritPohyb(soucastka, mnozstvi)
}

class VydejPohyb {
  duvod: String
  vytvoritPohyb(soucastka, mnozstvi)
}

class PresunutiPohyb {
  zdrojLokaceId: int
  cilLokaceId: int
  vytvoritPohyb(soucastka, mnozstvi)
  zmenLokaci()
}

abstract class SkladovyPohyb {
  id: int
  datum: Date
  stav: String
  mnozstvi: int
  {abstract} vytvoritPohyb(soucastka, mnozstvi)
  overitData()
  provestPohyb()
}

class Projekt {
  id: int
  nazev: String
  priradSoucastku(Soucastka)
  odeberSoucastku(Soucastka)
}

class ProjektSoucastka {
  mnozstvi: int
}

class Sklad {
  id: int
  nazev: String
  najdiSoucastku(id): Soucastka
}

class Lokace {
  id: int
  oznaceni: String
}

class Soucastka {
  id: int
  nazev: String
  mnozstvi: int
  rezervovaneMnozstvi: int
  stav: String
  zvysMnozstvi(pocet)
  snizMnozstvi(pocet)
  rezervovat(pocet)
  zrusitRezervaci(pocet)
  overDostupnost(): boolean
}

' ── Generalizace ──────────────────────────────────────────────────────────────
PrijemPohyb    --|> SkladovyPohyb
VydejPohyb     --|> SkladovyPohyb
PresunutiPohyb --|> SkladovyPohyb
Skladnik       --|> Uzivatel
VedouciSkladu  --|> Uzivatel

' ── Atribut spojení ───────────────────────────────────────────────────────────
(Projekt, Soucastka) .. ProjektSoucastka
Projekt -[hidden]left- ProjektSoucastka

' ── Kvalifikovaná vazba ───────────────────────────────────────────────────────
Sklad "[id: int]" --> "1" Soucastka : najdiSoucastku

' ── Asociace ──────────────────────────────────────────────────────────────────
SkladovyPohyb "*" --> "1" Soucastka     : je součástí
Sklad         "1" *-- "*" Lokace        : obsahuje
Lokace        "1" o-- "*" Soucastka     : ukládá
SkladovyPohyb "*" --> "1" Sklad         : mění stav
Skladnik      "1" --> "*" SkladovyPohyb : vytváří
VedouciSkladu "1" --> "*" SkladovyPohyb : vytváří
VedouciSkladu "1" --> "*" Projekt       : spravuje

' ── Layout ────────────────────────────────────────────────────────────────────
Skladnik    -[hidden]right- PrijemPohyb
PrijemPohyb -[hidden]right- VydejPohyb
VydejPohyb  -[hidden]right- PresunutiPohyb

@enduml
