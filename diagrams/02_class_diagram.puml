@startuml
top to bottom direction
skinparam CircledCharacterRadius 0
skinparam CircledCharacterFontSize 0
skinparam defaultFontSize 12
skinparam classFontSize 13
skinparam classFontStyle bold
skinparam nodesep 120
skinparam ranksep 120
skinparam Padding 4
skinparam ArrowFontSize 16

abstract class Uzivatel {
  id: int
  jmeno: String
  email: String
}

class Skladnik {
}

class VedouciSkladu {
}

class PrijemPohyb {
  dodavatel: String
  vytvoritPohyb(soucastka, mnozstvi)
}

class VydejPohyb {
  duvod: String
  vytvoritPohyb(soucastka, mnozstvi)
}

class PresunutiPohyb {
  zdrojLokaceId: int
  cilLokaceId: int
  vytvoritPohyb(soucastka, mnozstvi)
  zmenLokaci()
}

abstract class SkladovyPohyb {
  id: int
  datum: Date
  stav: String
  mnozstvi: int
  {abstract} vytvoritPohyb(soucastka, mnozstvi)
  overitData()
  provestPohyb()
}

class Projekt {
  id: int
  nazev: String
  priradSoucastku(Soucastka)
  odeberSoucastku(Soucastka)
}

class ProjektSoucastka {
  mnozstvi: int
}

class Sklad {
  id: int
  nazev: String
  najdiSoucastku(id): Soucastka
}

class Lokace {
  id: int
  oznaceni: String
}

class Soucastka {
  id: int
  nazev: String
  mnozstvi: int
  rezervovaneMnozstvi: int
  stav: String
  zvysMnozstvi(pocet)
  snizMnozstvi(pocet)
  rezervovat(pocet)
  zrusitRezervaci(pocet)
  overDostupnost(): boolean
  odepsat()
}

' -- Generalizace: -down-|> = child ABOVE parent
PrijemPohyb    -down-|> SkladovyPohyb
VydejPohyb     -down-|> SkladovyPohyb
PresunutiPohyb -down-|> SkladovyPohyb
Skladnik       -down-|> Uzivatel
VedouciSkladu  -down-|> Uzivatel

' -- ProjektSoucastka jako association class (cara z ProjektSoucastka na vazbu Projekt-Soucastka)
Projekt "\n1" -- "\n*" Soucastka
(Projekt, Soucastka) .. ProjektSoucastka

' -- Kvalifikovana vazba
Sklad "[id: int]" -right-> "\n1" Soucastka : \nnajdiSoucastku

' -- Asociace
VedouciSkladu "\n1" -right-> "\n*" Projekt       : \nspravuje
Skladnik      "\n1" -right-> "\n*" SkladovyPohyb : \nvytváří
SkladovyPohyb "\n*"  -->     "\n1" Sklad         : \nmění stav
SkladovyPohyb "\n*"  -->     "\n1" Soucastka     : \nje součástí
Sklad         "\n1" *--      "\n*" Lokace        : \nobsahuje
Lokace        "\n1" o-right- "\n*" Soucastka     : \nukládá

@enduml
